# ============================================================================
#  ClawdAgent v6.1 — Environment Configuration
#  Copy this file to .env and fill in your values
#  Only DATABASE_URL, JWT_SECRET, and ENCRYPTION_KEY are required
# ============================================================================

# --- Core ---
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# --- Database (REQUIRED) ---
DATABASE_URL=postgresql://user:password@localhost:5432/clawdagent
REDIS_URL=redis://localhost:6379

# --- Security (REQUIRED — generate with: openssl rand -hex 32) ---
JWT_SECRET=
ENCRYPTION_KEY=

# --- AI Providers (at least one required) ---
# Option 1: Anthropic direct
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096

# Option 2: OpenRouter (400+ models, many free)
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_STRONG_FALLBACK=google/gemini-2.5-flash
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1-0528:free
OPENROUTER_ECONOMY_MODEL=nvidia/nemotron-nano-9b-v2:free

# Option 3: Ollama (local, free)
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# Option 4: Claude Code CLI (free with Max subscription)
CLAUDE_CODE_ENABLED=true
CLAUDE_CODE_PATH=claude

# --- Model Router ---
PROVIDER_MODE=auto
PREFER_FREE_MODELS=true
DAILY_BUDGET_USD=2

# --- Chat Platforms (all optional) ---
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_ADMIN_IDS=

# WhatsApp (scan QR from web dashboard)
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_PATH=./data/whatsapp-session
WHATSAPP_ADMIN_IDS=

# Security: 'allowlist' = only admin IDs, 'open' = anyone
CHANNEL_SECURITY_MODE=allowlist

# --- Web Dashboard ---
BIND_HOST=127.0.0.1
REQUIRE_HTTPS=false
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# --- OpenClaw Bridge (optional) ---
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_DEVICE_ID=
OPENCLAW_DEVICE_PUBLIC_KEY=
OPENCLAW_DEVICE_PRIVATE_KEY=
OPENCLAW_DEVICE_TOKEN=
DOCUMENT_EXTRACTOR_ADAPTER_URL=
DOCUMENT_EXTRACTOR_ADAPTER_TIMEOUT_MS=30000
DOCUMENT_ADAPTER_EXTRA_EXTENSIONS=
ARTIFACT_ADAPTER_URL=
ARTIFACT_ADAPTER_TIMEOUT_MS=30000

# --- SSH Server Management (optional) ---
DEFAULT_SSH_SERVER=
DEFAULT_SSH_KEY_PATH=
SSH_ENABLED=false

# --- Email (optional) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Content & Media APIs (optional) ---
FAL_AI_API_KEY=
KIE_AI_API_KEY=
ELEVENLABS_API_KEY=
FIRECRAWL_API_KEY=
RAPIDAPI_KEY=
APIFY_API_TOKEN=
BRAVE_API_KEY=

# --- Social Media (optional) ---
BLOTATO_API_KEY=

# --- Crypto Trading (optional) ---
TRADING_ENABLED=false
TRADING_PAPER_MODE=true
TRADING_DEFAULT_EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Monitoring ---
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_MS=60000

# --- Misc ---
TTS_VOICE=nova
CRON_TIMEZONE=UTC
BROWSER_LOCALE=en-US
DESKTOP_ENABLED=false
